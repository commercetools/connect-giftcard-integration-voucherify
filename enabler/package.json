    "serve": "npm run build && serve public -l 3000 --cors"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "jest": "30.4.2",
    "sass": "1.99.0",
    "prettier": "^3.8.3",
    "ts-jest": "29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vite-plugin-css-injected-by-js": "3.5.2"
  },
  "dependencies": {
    "serve": "14.2.6"
  },
  "overrides": {
    "esbuild": "0.24.0"
  }
}
